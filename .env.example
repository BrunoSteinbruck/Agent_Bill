# ---------------------------------------------------------------------------
# Bill — backend environment
# Copy to `.env.local` and fill in. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# --- Supabase (auth + database) --------------------------------------------
# From the Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Lithic (virtual card issuance) ----------------------------------------
# Start in sandbox: https://lithic.com → Developers → API Keys
# Use the sandbox key + sandbox environment until Rain access is approved.
LITHIC_API_KEY=
LITHIC_ENVIRONMENT=sandbox
# Secret used to verify inbound transaction webhooks (HMAC).
LITHIC_WEBHOOK_SECRET=

# --- Crossmint (wallet infrastructure) -------------------------------------
# https://www.crossmint.com → Console → API Keys
# Free tier: up to 1,000 monthly active wallets.
CROSSMINT_API_KEY=
CROSSMINT_ENVIRONMENT=staging

# --- Anthropic (the Bill agent) --------------------------------------------
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- App ---------------------------------------------------------------------
# Public base URL, used to build webhook callback URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
